{
  "$schema": "../frontend/node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SoundBuddy",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../frontend/dist/frontend",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start --prefix ./frontend",
    "beforeBuildCommand": "npm run build --prefix ./frontend"
  },
  "app": {
    "windows": [
      {
        "title": "SoundBuddy",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
